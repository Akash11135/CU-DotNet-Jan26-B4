@model List<NorthwindCatalog.Services.DTOs.ProductDto>

<div class="container mt-4">
    <h2 class="mb-4 fw-bold">Products</h2>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card card-custom p-3">

                    <h5 class="fw-semibold">@item.ProductName</h5>

                    <p class="text-muted mb-1">Price: ₹@item.UnitPrice</p>
                    <p class="text-muted mb-1">Stock: @item.UnitsInStock</p>

                    <p class="fw-bold mt-2">
                        Inventory: ₹@item.InventoryValue
                    </p>

                </div>
            </div>
        }
    </div>
</div>
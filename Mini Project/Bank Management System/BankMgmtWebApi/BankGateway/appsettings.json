{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "authRoute": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "accountRoute": {
        "ClusterId": "accountCluster",
        "Match": {
          "Path": "/accounts/{**catch-all}"
        }
      },
      "transactionRoute": {
        "ClusterId": "transactionCluster",
        "Match": {
          "Path": "/transactions/{**catch-all}"
        }
      },
      "loanRoute": {
        "ClusterId": "loanCluster",
        "Match": {
          "Path": "/loans/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "authCluster": {
        "Destinations": {
          "authService": {
            "Address": "https://localhost:7001/"
          }
        }
      },
      "accountCluster": {
        "Destinations": {
          "accountService": {
            "Address": "https://localhost:7002/"
          }
        }
      },
      "transactionCluster": {
        "Destinations": {
          "transactionService": {
            "Address": "https://localhost:7003/"
          }
        }
      },
      "loanCluster": {
        "Destinations": {
          "loanService": {
            "Address": "https://localhost:7004/"
          }
        }
      }
    }
  }
}
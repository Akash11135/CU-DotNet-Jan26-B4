@model Client.DTOs.LoginDto

<style>
    .login-title {
        text-align: center;
        width: 100%;
    }

    .login-container {
        display: flex;
        margin: 50px;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .login-form-container {
        border: 1px solid whitesmoke;
        border-radius: 5px;
        padding: 1rem;
        min-width: 60%;
        background: rgb(245, 245, 245, 0.3);
    }
</style>

<div class="login-container">
    <div class="login-form-container">
        <h5>SmartBank 🏦</h5>
        <h1 class="login-title">Login</h1>
        <p>Welcome back! Please login.</p>

        <form method="post" asp-action="Login">

            <div class="form-fields">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" id="loginEmail" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-fields">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control" id="loginPassword" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between mt-2">
                <label>
                    <input type="checkbox" /> Remember me
                </label>
                <a href="#">Forgot password?</a>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-dark">Login</button>
                <button type="button" onclick="resetLogin()" class="btn btn-secondary">Reset</button>
            </div>

            <p style="text-align:center; margin-top:10px;">
                Don’t have an account?
                <a class="link link-dark" asp-action="Register" asp-controller="Auth"> Register</a>
            </p>

        </form>
    </div>
</div>

<script>
    function resetLogin(){
        var email = document.getElementById("loginEmail");
        var password = document.getElementById("loginPassword");

        email.value = "";
        password.value = "";
    }
</script>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
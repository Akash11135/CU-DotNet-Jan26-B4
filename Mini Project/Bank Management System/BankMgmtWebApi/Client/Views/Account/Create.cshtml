@model Client.DTOs.CreateAccountDto

<div class="page-box">
     <h1 class="page-title">Create Account</h1>
     <div class="mt-2">
         <form method="post" class="form">
             <div class="mt-2">
                <label class="form-label fw-bold" asp-for="Name"></label>
                <input class="form-control" type="text" required  asp-for="Name"/>
                <span class="text-danger" asp-validation-for="Name"></span>
             </div>
            <div class="mt-2">
                <label class="form-label fw-bold" asp-for="InitialDeposit"></label>
                <input class="form-control" type="number" required  min="1000" asp-for="InitialDeposit"/>
                <span class="text-danger" asp-validation-for="InitialDeposit" ></span>

             </div>
            <div class="mt-2">
                <button class="btn btn-success p-1 m-1" type="submit">Create</button>
                <a class="btn btn-secondary p-1 m-1" asp-action="GetAll" asp-controller="Account">Back</a>
             </div>
         </form>
     </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model Client.DTOs.AccountDto;


<style>
    .containerBox{
        margin-top:2rem;
        border: 1px solid lightgray;
        background-color:lightgray;
        padding:1rem;
        border-radius:3px;
        
    }
</style>

<div class="page-box">
    <h1 class="page-title">Account Details Page</h1>

    <div class="">
        <h2>Welcome👋, @Model.Name</h2>
        <div>
            <label class="form-label fw-bold">Id : </label>
            <span>@Model.Id</span>
        </div>
        <div class="">
            <label class="form-label fw-bold">Name : </label>
            <span>@Model.Name</span>
        </div>
        <div>
            <label class="form-label fw-bold">Account Number : </label>
            <span>@Model.AccountNumber</span>
        </div>
        <div>
            <label class="form-label fw-bold">Current Balance: </label>
            <span>Rs. @Model.Balance</span>
        </div>
        <div>
            <a class="btn btn-success p-1 mt-1 " asp-action="Edit" asp-controller="Account" asp-route-id=@Model.Id>Edit</a>
            <a asp-action="GetAll" asp-controller="Account" class="btn btn-dark p-1 mt-1 ">Back</a>
        </div>
    </div>   
    
</div>
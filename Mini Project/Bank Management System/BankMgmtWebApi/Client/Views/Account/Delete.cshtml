@model Client.DTOs.AccountDto

<div class="page-box">
    <h1 class="page-title text-danger">Delete Profile : @Model.Name</h1>
    
    <form method="post" class="form-clean">

        <!-- Hidden ID (important) -->
        <input type="hidden" asp-for="Id" />

        <div class="page-feild">
            <label asp-for="Id" class="form-label"></label>
            <input asp-for="Id" class="form-control" readonly style="cursor:not-allowed" />
        </div>
        <div class="page-feilds">
            <label asp-for="AccountNumber" class="form-label"></label>
            <input asp-for="AccountNumber" class="form-control" readonly style="cursor:not-allowed" />
        </div>

        <div class="page-feilds">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" readonly style="cursor:not-allowed" />
        </div>


        <div class ="page-feilds">
            <label asp-for="Balance" class="form-label"></label>
            <input asp-for="Balance" class="form-control" readonly style="cursor:not-allowed"/>
        </div>

        <!-- ✅ Button INSIDE form -->
        <div class="delete">
            <button class="btn btn-success mt-2" asp-action="DeleteConfirmed" asp-route-id=@Model.Id type="submit">Yes</button>
            <a asp-action="GetAll" class="btn btn-dark mt-2">No</a>
        </div>

    </form>
</div>
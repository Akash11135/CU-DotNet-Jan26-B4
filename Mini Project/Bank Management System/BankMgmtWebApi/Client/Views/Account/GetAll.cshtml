
@model List<Client.DTOs.AccountDto>



@{
    ViewData["Title"] = "All Accounts";
}


<div class="container">
<h1>Accounts</h1>
    <div class="mb-2">
        <a class="btn btn-dark" asp-controller="Account" asp-action="Create">Create Account</a>
    </div>
    <table class="table table-dark table-hover">
        <thead>
            <tr>
                <th>SNo</th>
                <th>Name</th>
                <th>Account Number</th>
                <th>Balance</th>
                <th>Acc Id</th>
                <th>History</th>
                <th>Add Transaction</th>
                <th>Actions</th>

            </tr>
        </thead>
        @{
            int cnt = 1;
        }
        <tbody>
            @foreach(var account in Model)
            {
                <tr>
                    <td>@cnt</td>
                    <td>@account.Name</td>
                    <td>@account.AccountNumber</td>
                    <td>Rs. @account.Balance</td>
                    <td>@account.Id</td>
                    <td>
                        <a class="btn btn-success">Transactions</a>
                    </td>
                    <td>
                        <a class="btn btn-outline-primary">Withdraw</a>
                        <a class="btn btn-outline-light ">Deposite</a>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-controller="Account" asp-route-id=@account.Id class="btn btn-outline-secondary p-1 m-1">Edit</a>
                        <a asp-action="Details" asp-controller="Account" asp-route-id=@account.Id class="btn btn-outline-info p-1 m-1">Details</a>
                        <a class="btn btn-outline-danger p-1 m-1">Delete</a>
                    </td>
                </tr>
                cnt++;  
            }
        </tbody>
</table>

</div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Bank🏦</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Client.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<style>
    /* Glassmorphism Navbar */
    .custom-navbar {
      
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        transition: all 0.3s ease-in-out;
    }

    /* Brand Styling */
    .navbar-brand {
        font-size: 1.5rem;
        letter-spacing: 1px;
    }

    /* Nav Links */
    .nav-link {
        position: relative;
        color: #fff !important;
        margin: 0 10px;
        transition: color 0.3s ease;
    }

    /* Hover Effect (underline animation) */
    .nav-hover::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: 0;
        width: 0%;
        height: 2px;
        background: #00d4ff;
        transition: width 0.3s ease;
    }

    .nav-hover:hover::after {
        width: 100%;
    }

    .nav-hover:hover {
        color: #00d4ff !important;
    }

    /* Optional: Navbar shadow on scroll */
    .custom-navbar.scrolled {
        background: rgba(0, 0, 0, 0.85);
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }
</style>
@{
    var token = Context.Request.Cookies["jwt"];
}
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark custom-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    Smart Bank🏦
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link nav-hover" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-hover" asp-controller="Home" asp-action="About">About</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-hover" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>

                        @{
                            if (string.IsNullOrWhiteSpace(token))
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-hover" asp-controller="Auth" asp-action="Login">Login</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-hover" asp-controller="Auth" asp-action="Logout">Logout</a>
                                </li>
                            }
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    
    <div class="content-wrapper">
        <main role="main" class="">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-light ">
        <div class="container">
            <div class="row">

                <!-- Bank Info -->
                <div class="col-md-4 mb-3">
                    <h5>🏦 Secure Bank</h5>
                    <p>
                        Providing reliable and secure banking services with a commitment to
                        innovation, trust, and customer satisfaction.
                    </p>
                </div>

                <!-- Quick Links -->
                <div class="col-md-2 mb-3">
                    <h6>Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-light text-decoration-none">Home</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Accounts</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Transfers</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Loans</a></li>
                    </ul>
                </div>

                <!-- Support -->
                <div class="col-md-3 mb-3">
                    <h6>Customer Support</h6>
                    <ul class="list-unstyled">
                        <li>Email: support@securebank.com</li>
                        <li>Phone: +91-1800-123-4567</li>
                        <li><a href="#" class="text-light text-decoration-none">Help Center</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Report Fraud</a></li>
                    </ul>
                </div>

                <!-- Legal -->
                <div class="col-md-3 mb-3">
                    <h6>Legal</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-light text-decoration-none">Privacy Policy</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Terms & Conditions</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Security</a></li>
                    </ul>
                </div>

            </div>

            <hr class="border-light" />

            <!-- Bottom Line -->
            <div class="text-center pb-3">
                <small>
                    © 2026 Secure Bank. All rights reserved. | Designed for secure financial services.
                </small>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Client</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Client.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<style>
    
</style>
@{
    var token = Context.Request.Cookies["jwt"];
}
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow ">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Client</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @{
                            if (string.IsNullOrWhiteSpace(token))
                            {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>

                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Logout">Logout</a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="content-wrapper">
        <main role="main" class="">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-light ">
        <div class="container">
            <div class="row">

                <!-- Bank Info -->
                <div class="col-md-4 mb-3">
                    <h5>🏦 Secure Bank</h5>
                    <p>
                        Providing reliable and secure banking services with a commitment to
                        innovation, trust, and customer satisfaction.
                    </p>
                </div>

                <!-- Quick Links -->
                <div class="col-md-2 mb-3">
                    <h6>Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-light text-decoration-none">Home</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Accounts</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Transfers</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Loans</a></li>
                    </ul>
                </div>

                <!-- Support -->
                <div class="col-md-3 mb-3">
                    <h6>Customer Support</h6>
                    <ul class="list-unstyled">
                        <li>Email: support@securebank.com</li>
                        <li>Phone: +91-1800-123-4567</li>
                        <li><a href="#" class="text-light text-decoration-none">Help Center</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Report Fraud</a></li>
                    </ul>
                </div>

                <!-- Legal -->
                <div class="col-md-3 mb-3">
                    <h6>Legal</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-light text-decoration-none">Privacy Policy</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Terms & Conditions</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Security</a></li>
                    </ul>
                </div>

            </div>

            <hr class="border-light" />

            <!-- Bottom Line -->
            <div class="text-center pb-3">
                <small>
                    © 2026 Secure Bank. All rights reserved. | Designed for secure financial services.
                </small>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

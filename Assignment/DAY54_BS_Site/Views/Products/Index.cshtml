@{
    ViewData["Title"] = "Products";
}

<div class="container mt-5">

    <h2 class="mb-4">Our Products</h2>

    <div class="row g-4">

        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-body">
                    <h4>Software</h4>
                    <p>Enterprise applications for businesses.</p>
                    <a asp-action="Software" class="btn btn-primary">View Software</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-body">
                    <h4>Tools</h4>
                    <p>Productivity tools to streamline workflows.</p>
                    <a asp-action="Tools" class="btn btn-success">View Tools</a>
                </div>
            </div>
        </div>

    </div>

</div>
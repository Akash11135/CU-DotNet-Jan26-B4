@{
    ViewData["Title"] = "Services";
}

<div class="container mt-5">

    <h2 class="mb-4">Our Services</h2>

    <div class="row g-4">

        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-body">
                    <h4>Consulting</h4>
                    <p>Professional IT consulting to help businesses adopt new technologies.</p>
                    <a asp-action="Consulting" class="btn btn-primary">Learn More</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-body">
                    <h4>Training</h4>
                    <p>Industry-oriented training programs for developers and teams.</p>
                    <a asp-action="Training" class="btn btn-success">Learn More</a>
                </div>
            </div>
        </div>

    </div>

</div>
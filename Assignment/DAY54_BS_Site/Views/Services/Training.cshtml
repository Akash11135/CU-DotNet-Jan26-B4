@{
    ViewData["Title"] = "Training";
}

<div class="container mt-5">

    <h2 class="mb-4">Training Programs</h2>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h5>Web Development</h5>
                    <span class="badge bg-primary">Popular</span>
                    <p class="mt-2">Learn modern full-stack development.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h5>Cloud Computing</h5>
                    <span class="badge bg-success">Trending</span>
                    <p class="mt-2">Master AWS and Azure cloud services.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h5>AI & Data Science</h5>
                    <span class="badge bg-warning">Advanced</span>
                    <p class="mt-2">Build machine learning applications.</p>
                </div>
            </div>
        </div>

    </div>

</div>
@{
    ViewData["Title"] = "BS-Site";
}

@{
    ViewData["Title"] = "Home";
}

<!-- HERO SLIDER -->
<main style="flex-grow:1">
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">

        <div class="carousel-inner">

            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085"
                     class="d-block w-100"
                     style="height:500px;object-fit:cover; opacity:40">

                <div class="carousel-caption">
                    <h1>Digital Innovation</h1>
                    <p>Transform your business with modern technology</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1551434678-e076c223a692"
                     class="d-block w-100"
                     style="height:500px;object-fit:cover;">

                <div class="carousel-caption">
                    <h1>Enterprise Solutions</h1>
                    <p>Build scalable software systems</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d"
                     class="d-block w-100"
                     style="height:500px;object-fit:cover;">

                <div class="carousel-caption">
                    <h1>Professional Training</h1>
                    <p>Upskill your team with modern technologies</p>
                </div>
            </div>

        </div>

        <button class="carousel-control-prev"
                type="button"
                data-bs-target="#heroCarousel"
                data-bs-slide="prev">

            <span class="carousel-control-prev-icon"></span>

        </button>

        <button class="carousel-control-next"
                type="button"
                data-bs-target="#heroCarousel"
                data-bs-slide="next">

            <span class="carousel-control-next-icon"></span>

        </button>

    </div>


    <!-- SERVICES SECTION -->

    <div class="container mt-5">

        <h2 class="text-center mb-4">Our Services</h2>

        <div class="row g-4">

            <div class="col-md-4">

                <div class="card shadow border-0 h-100">

                    <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216"
                         class="card-img-top"
                         style="height:200px;object-fit:cover;">

                    <div class="card-body text-center">

                        <h5>Consulting</h5>

                        <p>Strategic consulting for businesses adopting modern technology.</p>

                        <a asp-controller="Services" asp-action="Consulting"
                           class="btn btn-outline-primary">
                            Learn More
                        </a>

                    </div>

                </div>

            </div>


            <div class="col-md-4">

                <div class="card shadow border-0 h-100">

                    <img src="https://images.unsplash.com/photo-1518770660439-4636190af475"
                         class="card-img-top"
                         style="height:200px;object-fit:cover;">

                    <div class="card-body text-center">

                        <h5>Software Development</h5>

                        <p>Enterprise applications built with modern architecture.</p>

                        <a asp-controller="Products" asp-action="Software"
                           class="btn btn-outline-success">
                            View Products
                        </a>

                    </div>

                </div>

            </div>


            <div class="col-md-4">

                <div class="card shadow border-0 h-100">

                    <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c"
                         class="card-img-top"
                         style="height:200px;object-fit:cover;">

                    <div class="card-body text-center">

                        <h5>Training Programs</h5>

                        <p>Professional training for developers and organizations.</p>

                        <a asp-controller="Services" asp-action="Training"
                           class="btn btn-outline-warning">
                            Explore
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>


    <!-- FEATURES SECTION -->

    <div class="container mt-5">

        <h2 class="text-center mb-4">Why Choose Us</h2>

        <div class="row text-center">

            <div class="col-md-4">

                <h3>500+</h3>

                <p>Successful Projects</p>

            </div>

            <div class="col-md-4">

                <h3>200+</h3>

                <p>Global Clients</p>

            </div>

            <div class="col-md-4">

                <h3>50+</h3>

                <p>Expert Developers</p>

            </div>

        </div>

    </div>


    <!-- CALL TO ACTION -->

    <div class="bg-dark text-white text-center p-5 mt-5">

        <h2>Ready to Start Your Project?</h2>

        <p>Let's build something amazing together.</p>

        <a asp-controller="Contact" asp-action="Index"
           class="btn btn-primary btn-lg">
            Contact Us
        </a>

    </div>
</main>
